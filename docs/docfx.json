{
  "metadata": [
    {
      "src": [
        {
          "files": [ "src/DotNet.Multithreading.Examples/**/*.cs" ],
          "src": "../"
        }
      ],
      "dest": "api",
      "disableGitFeatures": false,
      "disableDefaultFilter": false
    }
  ],
  "build": {
    "content": [
      {
        "files": [ "api/**.yml", "api/index.md" ]
      },
      {
        "files": [ "articles/**.md", "articles/**/toc.yml", "toc.yml", "*.md" ]
      }
    ],
    "resource": [
      {
        "files": [ "images/**" ]
      }
    ],
    "output": "_site",
    "template": [ "default", "modern" ],
    "globalMetadata": {
      "_appName": ".NET Multithreading Examples",
      "_appTitle": ".NET Multithreading Examples",
      "_appFooter": "A .NET 10 multi-threading learning repository",
      "_enableSearch": true
    }
  }
}
